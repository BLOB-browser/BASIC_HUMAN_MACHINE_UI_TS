{
  "name": "@blob-browser/ui",
  "version": "0.4.0",
  "description": "BASIC HUMAN MACHINE UI \u2014 design tokens and components for the BLOB ecosystem",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/BLOB-browser/BASIC_HUMAN_MACHINE_UI_TS.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    },
    "./themes": {
      "types": "./dist/themes/index.d.ts",
      "import": "./dist/themes/index.js",
      "require": "./dist/themes/index.cjs"
    },
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.js",
      "require": "./dist/tailwind-preset.cjs"
    },
    "./styles": {
      "default": "./dist/styles/index.css"
    },
    "./styles/base": {
      "default": "./dist/styles/base.css"
    },
    "./styles/fonts": {
      "default": "./dist/styles/fonts.css"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && npm run build:css",
    "build:css": "postcss src/styles/index.css -o dist/styles/index.css && cp src/styles/base.css dist/styles/base.css && cp src/styles/fonts.css dist/styles/fonts.css && mkdir -p dist/fonts && ls src/styles/fonts/*.css 2>/dev/null && for f in src/styles/fonts/*.css; do cp \"$f\" \"dist/fonts/$(basename $f)\"; done || true",
    "dev": "tsup --watch",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/libre-franklin": "^5.2.8",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@fontsource-variable/noto-serif": "^5.2.9",
    "@fontsource-variable/roboto": "^5.2.10",
    "@fontsource-variable/roboto-serif": "^5.2.9",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-serif": "^5.2.7",
    "@fontsource/libre-baskerville": "^5.2.10",
    "@fontsource/noto-sans-mono": "^5.2.10",
    "@fontsource/pt-mono": "^5.2.8",
    "@fontsource/pt-sans": "^5.2.8",
    "@fontsource/pt-serif": "^5.2.8",
    "@fontsource/roboto-mono": "^5.2.9",
    "@fontsource/source-code-pro": "^5.2.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0"
  },
  "peerDependencies": {
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "sonner": "^2.0.7"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-radio-group": "^1.4.0",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "sonner": "^2.0.7",
    "storybook": "^10.4.2",
    "tailwindcss": "^3.4.19",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^8.0.16"
  }
}
