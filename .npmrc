# Route @building-local-open-bots-scoped packages to GitHub Packages.
# The NODE_AUTH_TOKEN env var is set automatically by GitHub Actions (actions/setup-node).
# For local publishing: export NODE_AUTH_TOKEN=<your GitHub PAT with write:packages>
@building-local-open-bots:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
